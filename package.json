{
  "name": "tiletest",
  "private": true,
  "type": "module",
  "scripts": {
    "serve": "python -m http.server 5000",
    "lint": "eslint . --ext .js",
    "test:content": "vitest run tests/content",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "check": "npm run lint && npm run test:content && npm run test:unit",
    "test": "npm run check && npm run test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "^9.3.0",
    "@playwright/test": "^1.52.0",
    "eslint": "^9.3.0",
    "globals": "^15.3.0",
    "vitest": "^4.1.7"
  }
}
